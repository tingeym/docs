  "keyFeatures": [
    "We-Commerce platform for direct sales and MLM organizations",
    "Fluid Connect: bi-directional sync with Exigo, ByDesign, Pillars, InfoTrax, Shopify",
    "Fluid Payments: global payment aggregator supporting 300+ APMs in 100+ countries",
    "Fair Share SDK: multi-domain affiliate attribution using cookies, fingerprints, and routes",
    "We-Commerce Checkout: one-page checkout with tax, shipping, inventory, and discounts",
    "Fluid Login: unified authentication with SSO, MFA, magic links, and social providers",
    "Droplet Marketplace: single-click third-party app installs",
    "App Builder: custom mobile and desktop apps via drag-and-drop",
    "Website Editor: Liquid-powered theme system with GitHub integration",
    "Digital Asset Management (DAM) with AI image tools",
    "Fluid Orchestration: intelligent payment routing across multiple PSPs",
    "International commerce support for 9+ markets"
  ],
  "publicApiSurface": [
